# ─────────────────────────────────────────────────────────────────────────────
# BhartX Academy — Backend Environment Variables
# Copy this file to .env and fill in the values before running locally.
# On Render, set these via: Dashboard → Service → Environment → Add Env Var
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" on Render. Enables CSRF checks, disables debug docs.
ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. Server will refuse to start with the default key.
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: uses SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./bhartx_academy.db

# Production (Render PostgreSQL): uncomment and set your Render DB URL
# DATABASE_URL=postgresql://user:password@host:5432/bhartx_db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example:
# ALLOWED_ORIGINS=https://bhartx-academy.vercel.app,https://www.bhartx.in

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# REQUIRED in production for Google Login.
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID

# ── AI Keys ───────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Optional: OpenAI fallback
# OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_API_KEY
